  <ellipse cx="140" cy="218" rx="118" ry="5" fill="#2b3036" fill-opacity="0.06"/>

  <!-- Linke Seite -->
  <rect x="5" y="5" width="126" height="206" rx="3" fill="#fbfaf7" stroke="#2b3036" stroke-opacity="0.11" stroke-width="0.8"/>

  <!-- Rotes Randlineal (Notizbuch-typisch) -->
  <line x1="26" y1="7" x2="26" y2="209" stroke="#fc551e" stroke-width="0.9" stroke-opacity="0.35"/>

  <!-- Lineatur links -->
  <g stroke="#2b3036" stroke-opacity="0.065" stroke-width="0.55">
    <line x1="5" y1="38" x2="131" y2="38"/>
    <line x1="5" y1="54" x2="131" y2="54"/>
    <line x1="5" y1="70" x2="131" y2="70"/>
    <line x1="5" y1="86" x2="131" y2="86"/>
    <line x1="5" y1="102" x2="131" y2="102"/>
    <line x1="5" y1="118" x2="131" y2="118"/>
    <line x1="5" y1="134" x2="131" y2="134"/>
    <line x1="5" y1="150" x2="131" y2="150"/>
    <line x1="5" y1="166" x2="131" y2="166"/>
    <line x1="5" y1="182" x2="131" y2="182"/>
    <line x1="5" y1="198" x2="131" y2="198"/>
  </g>

  <!-- Linke Seite: Inhalt -->
  <!-- Überschrift (dicker Block) -->
  <rect x="33" y="14" width="86" height="10" rx="2.5" fill="#2b3036" fill-opacity="0.7"/>

  <!-- Fließtext-Zeilen -->
  <rect x="33" y="42" width="92" height="6" rx="2" fill="#2b3036" fill-opacity="0.2"/>
  <rect x="33" y="58" width="82" height="6" rx="2" fill="#2b3036" fill-opacity="0.2"/>
  <rect x="33" y="74" width="90" height="6" rx="2" fill="#2b3036" fill-opacity="0.2"/>

  <!-- Handspur-Unterstreichung -->
  <rect x="33" y="81" width="58" height="2.5" rx="1" fill="#fc551e" fill-opacity="0.65"/>

  <!-- Weiterer Text -->
  <rect x="33" y="90" width="70" height="6" rx="2" fill="#2b3036" fill-opacity="0.14"/>
  <rect x="33" y="106" width="95" height="6" rx="2" fill="#2b3036" fill-opacity="0.14"/>

  <!-- Drei Hebel — Pill-Tags -->
  <rect x="33" y="120" width="32" height="13" rx="6.5" fill="#14b4be" fill-opacity="0.13" stroke="#14b4be" stroke-width="0.9" stroke-opacity="0.5"/>
  <rect x="39" y="124.5" width="20" height="4" rx="1.5" fill="#14b4be" fill-opacity="0.6"/>

  <rect x="70" y="120" width="30" height="13" rx="6.5" fill="#14b4be" fill-opacity="0.13" stroke="#14b4be" stroke-width="0.9" stroke-opacity="0.5"/>
  <rect x="75" y="124.5" width="19" height="4" rx="1.5" fill="#14b4be" fill-opacity="0.6"/>

  <rect x="105" y="120" width="26" height="13" rx="6.5" fill="#14b4be" fill-opacity="0.13" stroke="#14b4be" stroke-width="0.9" stroke-opacity="0.5"/>
  <rect x="110" y="124.5" width="16" height="4" rx="1.5" fill="#14b4be" fill-opacity="0.6"/>

  <!-- Weitere Text-Zeilen -->
  <rect x="33" y="138" width="78" height="6" rx="2" fill="#2b3036" fill-opacity="0.11"/>
  <rect x="33" y="154" width="90" height="6" rx="2" fill="#2b3036" fill-opacity="0.11"/>
  <rect x="33" y="170" width="62" height="6" rx="2" fill="#2b3036" fill-opacity="0.11"/>

