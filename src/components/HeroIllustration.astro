    <circle cx="140" cy="26"  r="4.5"/>
    <circle cx="140" cy="52"  r="4.5"/>
    <circle cx="140" cy="78"  r="4.5"/>
    <circle cx="140" cy="104" r="4.5"/>
    <circle cx="140" cy="130" r="4.5"/>
    <circle cx="140" cy="156" r="4.5"/>
    <circle cx="140" cy="182" r="4.5"/>
    <circle cx="140" cy="208" r="4.5"/>
  </g>
  <!-- Spirale inner highlight -->
  <line x1="134" y1="5" x2="134" y2="213" stroke="white" stroke-opacity="0.22" stroke-width="1.2"/>

  <!-- Rechte Seite -->
  <rect x="149" y="5" width="126" height="206" rx="3" fill="#fbfaf7" stroke="#2b3036" stroke-opacity="0.11" stroke-width="0.8"/>

  <!-- Lineatur rechts -->
  <g stroke="#2b3036" stroke-opacity="0.065" stroke-width="0.55">
    <line x1="149" y1="38" x2="275" y2="38"/>
    <line x1="149" y1="54" x2="275" y2="54"/>
    <line x1="149" y1="70" x2="275" y2="70"/>
    <line x1="149" y1="86" x2="275" y2="86"/>
    <line x1="149" y1="102" x2="275" y2="102"/>
    <line x1="149" y1="118" x2="275" y2="118"/>
    <line x1="149" y1="134" x2="275" y2="134"/>
    <line x1="149" y1="150" x2="275" y2="150"/>
    <line x1="149" y1="166" x2="275" y2="166"/>
    <line x1="149" y1="182" x2="275" y2="182"/>
    <line x1="149" y1="198" x2="275" y2="198"/>
  </g>

  <!-- Rechte Seite: Abschnitts-Überschrift -->
  <rect x="159" y="14" width="62" height="8" rx="2" fill="#2b3036" fill-opacity="0.55"/>

  <!-- Balken-Diagramm (drei Hebel) -->
