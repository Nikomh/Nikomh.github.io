  <line x1="158" y1="108" x2="236" y2="108" stroke="#2b3036" stroke-opacity="0.14" stroke-width="0.7"/>

  <!-- Motivation — hoch, Türkis -->
  <rect x="163" y="58" width="21" height="50" rx="3" fill="#14b4be" fill-opacity="0.7"/>
  <!-- Können — mittel, Türkis gedämpft -->
  <rect x="192" y="76" width="21" height="32" rx="3" fill="#14b4be" fill-opacity="0.45"/>
  <!-- Umfeld — niedrig, Handspur (schwächster Hebel) -->
  <rect x="221" y="93" width="21" height="15" rx="3" fill="#fc551e" fill-opacity="0.5"/>

  <!-- Balken-Beschriftungs-Striche -->
  <rect x="162" y="113" width="22" height="3.5" rx="1" fill="#5c626a" fill-opacity="0.3"/>
  <rect x="191" y="113" width="22" height="3.5" rx="1" fill="#5c626a" fill-opacity="0.3"/>
  <rect x="220" y="113" width="22" height="3.5" rx="1" fill="#5c626a" fill-opacity="0.3"/>

  <!-- Checkliste -->
  <!-- Abschnitts-Kopf -->
  <rect x="159" y="128" width="50" height="7" rx="2" fill="#2b3036" fill-opacity="0.5"/>

  <!-- Item 1: erledigt -->
  <circle cx="165" cy="148" r="5.5" fill="none" stroke="#14b4be" stroke-width="1.3"/>
  <path d="M162 148 L164.5 151 L169.5 144" fill="none" stroke="#14b4be" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  <rect x="176" y="144" width="72" height="6" rx="2" fill="#2b3036" fill-opacity="0.2"/>

  <!-- Item 2: erledigt -->
  <circle cx="165" cy="164" r="5.5" fill="none" stroke="#14b4be" stroke-width="1.3"/>
  <path d="M162 164 L164.5 167 L169.5 160" fill="none" stroke="#14b4be" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  <rect x="176" y="160" width="62" height="6" rx="2" fill="#2b3036" fill-opacity="0.2"/>

  <!-- Item 3: offen, Handspur (in progress) -->
  <circle cx="165" cy="180" r="5.5" fill="none" stroke="#fc551e" stroke-width="1.3"/>
  <rect x="176" y="176" width="80" height="6" rx="2" fill="#2b3036" fill-opacity="0.28"/>

  <!-- Item 4: pending -->
  <circle cx="165" cy="196" r="5.5" fill="none" stroke="#2b3036" stroke-opacity="0.18" stroke-width="1" stroke-dasharray="2.5 2.5"/>
  <rect x="176" y="192" width="56" height="6" rx="2" fill="#2b3036" fill-opacity="0.1"/>

  <!-- Datumsstempel rechts -->
  <rect x="159" y="202" width="42" height="3.5" rx="1" fill="#5c626a" fill-opacity="0.26"/>
</svg>
