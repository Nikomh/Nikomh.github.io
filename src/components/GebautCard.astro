---
interface Props { href: string; title: string; description: string; datum: Date; status: string; }
const { href, title, description, datum, status } = Astro.props;
const d = datum.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
---
<a href={href} class="group flex items-center gap-5 rounded-[10px] border border-tinte/15 bg-karte p-5 transition-colors hover:border-lagune">
  <div class="relative hidden h-24 w-36 shrink-0 rounded-lg bg-[#e9e6e0] sm:block" aria-hidden="true">
    <span class="absolute left-2.5 top-2 text-[10px] text-grau">screenshot</span>
    <svg class="absolute bottom-3 right-3" width="56" height="36" aria-hidden="true"><ellipse cx="28" cy="18" rx="25" ry="14" fill="none" stroke="#fc551e" stroke-width="3" transform="rotate(-3 28 18)" /></svg>
  </div>
  <div>
    <span class="text-[11.5px] font-bold uppercase tracking-wide text-grau">{status}</span>
    <p class="mt-1 font-bold leading-snug group-hover:underline">{title}</p>
    <p class="mt-1 text-sm leading-relaxed text-grau">{description}</p>
    <p class="mt-2 text-xs text-grau">Notiert am {d}</p>
  </div>
</a>
