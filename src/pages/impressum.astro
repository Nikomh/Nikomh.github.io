---
import BaseLayout from '../layouts/BaseLayout.astro';
// ⚠️ PLATZHALTER — vor dem offiziellen Launch mit echten Angaben füllen (Pflicht nach § 5 DDG).
---
<BaseLayout title="Impressum — Nikolay" description="Impressum">
  <h1 class="pt-6 text-3xl font-bold">Impressum</h1>
  <div class="prose-notiz mt-6 max-w-prose">
    <p><strong>Angaben gemäß § 5 DDG</strong></p>
    <p>
      Nikolay [Nachname]<br />
      [Straße Hausnummer]<br />
      [PLZ Ort]
    </p>
    <p>
      E-Mail: [E-Mail-Adresse]<br />
      Telefon: [Telefonnummer]
    </p>
    <p><strong>Verantwortlich für den Inhalt:</strong> Nikolay [Nachname], Anschrift wie oben.</p>
    <p class="text-sm" style="color:#5c626a">
      Hinweis: Diese Seite ist noch ein Platzhalter — die Site befindet sich im Aufbau und ist noch nicht offiziell veröffentlicht.
    </p>
  </div>
</BaseLayout>
