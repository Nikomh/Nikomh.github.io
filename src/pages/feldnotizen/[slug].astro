---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Handspur from '../../components/Handspur.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notizen = await getCollection('feldnotizen');
  return notizen.map((n) => ({ params: { slug: n.slug }, props: { n } }));
}
const { n } = Astro.props;
const { Content } = await n.render();
const d = n.data.date.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
const words = n.body.split(/\s+/).length;
const min = Math.max(1, Math.round(words / 200));
---
<BaseLayout title={`${n.data.title} — Feldnotizen`} description={n.data.description}>
  <article class="mx-auto max-w-prose pt-6">
    <p class="text-xs font-bold uppercase tracking-wide text-lagune">{n.data.kategorie}<span class="ml-2 font-normal normal-case tracking-normal text-grau">· Notiert am {d} · {min} Min Lesezeit</span></p>
    <h1 class="mt-3 text-[1.9rem] font-bold leading-tight sm:text-4xl"><Handspur>{n.data.title}</Handspur></h1>
    <p class="mt-4 text-lg leading-relaxed text-grau">{n.data.description}</p>
    <div class="prose-notiz mt-8"><Content /></div>
    <div class="mt-10 rounded-[10px] border border-tinte/15 bg-karte p-5 text-sm leading-relaxed">
      <p>Diese Notiz weitergedacht? <a class="text-lagune underline" href="mailto:TODO@TODO.de">Schreiben Sie mir</a> — ich lese alles.</p>
      <p class="mt-1 text-grau">Oder abonnieren Sie die nächste: <a class="text-lagune underline" href="/#newsletter">Newsletter</a>, alle zwei Wochen, ohne Pitch.</p>
    </div>
  </article>
</BaseLayout>
